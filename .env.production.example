# =============================================================================
# InsightReviews — Production Environment Variables
# =============================================================================
# These values should be set in your Vercel project settings:
#   https://vercel.com/your-team/insightreviews/settings/environment-variables
#
# NEVER commit real secrets to the repository.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Production project)
# -----------------------------------------------------------------------------
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# Use your production Supabase project, NOT localhost.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-production-service-role-key

# -----------------------------------------------------------------------------
# Site URL
# -----------------------------------------------------------------------------
# Your production domain. Must match the URL configured in Supabase Auth
# settings (Authentication > URL Configuration > Site URL).
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# Stripe (Live keys)
# -----------------------------------------------------------------------------
# Switch to live keys from: https://dashboard.stripe.com/apikeys
# Make sure you have created the product/price in live mode too.
STRIPE_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Production webhook secret — create a webhook endpoint in Stripe Dashboard
# pointing to https://your-domain.com/api/stripe/webhook
# Events to subscribe: checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.payment_succeeded, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price IDs for tiered plans (must exist in live mode)
# STRIPE_PRICE_ID is used as fallback for Starter if STRIPE_PRICE_ID_STARTER is not set
STRIPE_PRICE_ID=price_xxx
STRIPE_PRICE_ID_STARTER=price_starter_xxx
STRIPE_PRICE_ID_GROWTH=price_growth_xxx
STRIPE_PRICE_ID_AGENCY=price_agency_xxx

# -----------------------------------------------------------------------------
# Twilio (Production)
# -----------------------------------------------------------------------------
# Same credentials work for both test and production.
# Ensure your Twilio number is approved for production SMS.
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+1234567890
